extends ../../layouts/page.pug

block title
  = t('views.users.index.title')

block content
  .table-responsive
    table.table.table-borderless.table-striped.mt-5.bg-white
      thead
        tr
          th= t('users.fields.id')
          th= t('users.fields.full_name')
          th= t('users.fields.email')
          th= t('users.fields.created_at')
          th= t('common.actions')
      tbody
        each user in users
          tr
            td= user.id
            td= user.fullName
            td= user.email
            td= formatDate(user.createdAt)
            td
              .d-flex.flex-wrap
                a.btn.btn-primary.me-1(href=route('users.edit', { id: user.id }))= t('actions.edit')
                +form(route('users.delete', {id: user.id}), "delete")(class="mb-0")
                  +submit(t('actions.delete'))(class="btn-danger")
