extends ../../layouts/page.pug

block title
  = t('views.tasks.index.title')

block content
  a.btn.btn-primary(href=route('tasks.new'))= t('views.tasks.index.new')

  .card.shadow-sm.my-4
    .card-body.p-4
      +form(route('tasks.index'), 'GET')
        .row
          .col-12.col-md
            +selectGroup(
              t('views.tasks.index.filters.status'),
              'status',
              statuses.map(({ id, name }) => ({ value: id, label: name })),
              status
            )
          .col-12.col-md
            +selectGroup(
              t('views.tasks.index.filters.executor'),
              'executor',
              users.map(({ id, fullName }) => ({ value: id, label: fullName })),
              executor
            )
          .col-12.col-md
            +selectGroup(
              t('views.tasks.index.filters.label'),
              'label',
              labels.map(({ id, name }) => ({ value: id, label: name })),
              label
            )
        .mb-3.form-check
          input#data_isCreatorUser.form-check-input(
            type="checkbox"
            name="isCreatorUser"
            value="1"
            checked=isCreatorUser
          )

          label.form-check-label(for="data_isCreatorUser")= t('views.tasks.index.filters.is_creator_user')
        +submit(t('actions.show'))

  .table-responsive
    table.table.table-borderless.table-striped.mt-5.bg-white
      thead
        tr
          th= t('tasks.fields.id')
          th= t('tasks.fields.name')
          th= t('tasks.fields.status')
          th= t('tasks.fields.creator')
          th= t('tasks.fields.executor')
          th= t('tasks.fields.created_at')
          th= t('common.actions')
      tbody
        each task in tasks
          tr
            td= task.id
            td
              a(href=route('tasks.show', { id: task.id }))= task.name
            td= task.status.name
            td= task.creator.fullName
            td= task.executor ? task.executor.fullName : ''
            td= formatDate(task.createdAt)
            td
              .d-flex.flex-wrap
                a.btn.btn-primary.me-1(href=route('tasks.edit', { id: task.id }))= t('actions.edit')
                +form(route('tasks.delete', {id: task.id}), "delete")(class="mb-0")
                  +submit(t('actions.delete'))(class="btn-danger")
